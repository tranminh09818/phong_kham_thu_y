<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console Appender cho Development -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File Appender cho Production (với Structured JSON Format - Mocked text for simplicity) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/rexi-backend.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/rexi-backend-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- Sử dụng Pattern layout dạng text có cấu trúc để các công cụ gom log dễ đọc -->
            <pattern>{"time":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%level","thread":"%thread","logger":"%logger{36}","message":"%msg"}%n</pattern>
        </encoder>
    </appender>

    <!-- Cấu hình mức độ Log -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

    <!-- Tắt các log quá ồn ào từ thư viện bên thứ 3 -->
    <logger name="org.hibernate" level="WARN" />
    <logger name="com.zaxxer.hikari" level="WARN" />
    <logger name="org.springframework.web" level="INFO" />
    <logger name="org.springframework.security" level="WARN" />
    
    <!-- Ghi log chi tiết cho hệ thống Rexi -->
    <logger name="com.rexi.pkty" level="DEBUG" />
</configuration>

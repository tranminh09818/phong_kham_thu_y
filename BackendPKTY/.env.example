# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_URL=jdbc:sqlserver://localhost;databaseName=PhongKhamThuY;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=123456

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_super_secret_key_change_this_in_production_immediately_use_min_32_chars
JWT_EXPIRATION=86400000

# ============================================
# AI API KEYS (KEEP SECURE!)
# ============================================
# Get Groq API Key from: https://console.groq.com
GROQ_API_KEY=

# Get Gemini API Key from: https://ai.google.dev/
GEMINI_API_KEY=

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
